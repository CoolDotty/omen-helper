<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <ApplicationManifest>OmenHelper.manifest</ApplicationManifest>
    <TargetFramework>net48</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>disable</Nullable>
    <ImplicitUsings>false</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <Prefer32Bit>false</Prefer32Bit>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <AssemblyName>OmenHelper</AssemblyName>
    <RootNamespace>OmenHelper</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="HP.Omen.Core.Common">
      <HintPath>C:\Program Files\HP\SystemOptimizer\HP.Omen.Core.Common.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="HP.Omen.Core.Model.DataStructure">
      <HintPath>C:\Program Files\HP\SystemOptimizer\HP.Omen.Core.Model.DataStructure.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="PerformanceControl">
      <HintPath>C:\Program Files\HP\SystemOptimizer\PerformanceControl.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="System.Management" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Resources.Extensions" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="dlldumps\**\*.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Include="RESEARCH_NOTES.md">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
